---
import Layout from "../layouts/Layout.astro";
import ProductsGrid from "@dynage/ui/astro/ProductsGrid.astro";
---

<Layout title="Products | Dynage Studio">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-6 tracking-tighter leading-none uppercase"
      >
        Digital <span class="text-blue-600">Products</span>
      </h1>
      <p
        class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto font-medium"
      >
        Explore our suite of scalable, high-performance software products
        designed to transform business operations.
      </p>
    </div>
  </section>

  <ProductsGrid />
</Layout>
