---
import Layout from "../layouts/Layout.astro";
import Section from "@dynage/ui/astro/Section.astro";
import { client } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";

// Fetch all studio products from Sanity
const products =
  await client.fetch(`*[_type == "product"] | order(publishedAt desc) {
  name,
  "slug": slug.current,
    "excerpt": pt::text(description),
  mainImage,
  publishedAt
}`);

---

<Layout title="Products | Dynage Studio">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-6 tracking-tighter leading-none uppercase"
      >
        Digital <span class="text-blue-600">Products</span>
      </h1>
      <p
        class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto font-medium"
      >
        Explore our suite of scalable, high-performance software products
        designed to transform business operations.
      </p>
    </div>
  </section>

  <main class="pb-32">
    <Section>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-4">
        {
          products.map((product: any) => (
            <div class="group block bg-gray-50 dark:bg-zinc-900 rounded-[2.5rem] overflow-hidden border border-gray-100 dark:border-zinc-800 transition-all hover:shadow-2xl hover:shadow-blue-500/5 hover:-translate-y-2">
              <div class="aspect-[16/9] overflow-hidden bg-gray-200 dark:bg-zinc-800">
                {product.mainImage ? (
                  <img
                    src={urlFor(product.mainImage).width(1200).url()}
                    alt={product.name}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-400 font-bold uppercase tracking-widest text-xs">
                    Product Image Coming Soon
                  </div>
                )}
              </div>
              <div class="p-10">
                <h3 class="text-3xl font-black tracking-tighter mb-4 uppercase group-hover:text-blue-600 transition-colors">
                  {product.name}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 font-medium leading-relaxed">
                  {product.excerpt?.length > 100
                    ? product.excerpt.substring(0, 100) + "..."
                    : product.excerpt}
                </p>

                <div class="mt-8 flex items-center text-black dark:text-white font-black uppercase text-sm tracking-widest cursor-pointer">
                  View Product Details
                  <div class="ml-4 w-10 h-10 rounded-full border border-black/10 dark:border-white/10 flex items-center justify-center transition-colors group-hover:bg-blue-600 group-hover:border-blue-600 group-hover:text-white">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </Section>
  </main>
</Layout>
