---
import Layout from "../layouts/Layout.astro";
import Section from "@dynage/ui/astro/Section.astro";
import { client } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";

// Fetch publications (posts) from Sanity
const publications = await client.fetch(`*[_type == "post" && "Research" in categories[]->title] | order(publishedAt desc) {
  title,
  "slug": slug.current,
  mainImage,
  publishedAt,
  "excerpt": pt::text(body)
}`);

function formatDate(date: string) {
  return new Date(date).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric"
  });
}
---

<Layout title="Publications | Dynage Research">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-none">
        Scientific <br />
        <span class="text-blue-600">Publications</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
        Discover our latest findings, industry whitepapers, and theoretical breakthroughs.
      </p>
    </div>
  </section>

  <main class="pb-32">
    <Section>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-4">
        {publications.length > 0 ? (
          publications.map((pub: any) => (
            <div class="group flex flex-col bg-gray-50 dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 rounded-[3rem] overflow-hidden transition-all hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-2">
              <div class="aspect-video overflow-hidden bg-gray-200 dark:bg-zinc-800">
                {pub.mainImage ? (
                  <img 
                    src={urlFor(pub.mainImage).width(1200).url()} 
                    alt={pub.title}
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-gray-400 font-bold uppercase tracking-widest">
                    {pub.title}
                  </div>
                )}
              </div>
              <div class="p-10 flex-1 flex flex-col">
                <div class="text-[10px] uppercase tracking-[0.2em] font-black text-blue-600 mb-4 px-3 py-1 bg-blue-500/10 rounded-full self-start">
                   {formatDate(pub.publishedAt)}
                </div>
                <h3 class="text-3xl font-black mb-4 group-hover:text-blue-600 transition-colors">
                  {pub.title}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-10 line-clamp-3">
                  {pub.excerpt}
                </p>
                <div class="mt-auto pt-6 border-t border-gray-100 dark:border-zinc-800">
                   <a href={`/blog/${pub.slug}`} class="inline-flex items-center text-blue-600 font-black text-sm uppercase tracking-widest">
                      Read Publication
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                      </svg>
                   </a>
                </div>
              </div>
            </div>
          ))
        ) : (
          <div class="col-span-full py-32 text-center">
             <div class="text-6xl mb-8 animate-bounce">🧪</div>
             <h2 class="text-3xl font-black mb-4">Labs are humming...</h2>
             <p class="text-gray-500 max-w-md mx-auto">Our researchers are currently finalising the first wave of publications. Check back soon for the latest breakthroughs.</p>
          </div>
        )}
      </div>
    </Section>
  </main>
</Layout>
