---
import Layout from "../layouts/Layout.astro";
import Section from "@dynage/ui/astro/Section.astro";
import SectionSpacer from "@dynage/ui/astro/SectionSpacer.astro";
import StatsGrid from "@dynage/ui/astro/StatsGrid.astro";
import IndustryCard from "@dynage/ui/astro/IndustryCard.astro";
import { client } from "@dynage/contents/client";
import { SITE } from "../consts";

// Fetch dynamic page content from Sanity
const pageData = await client.fetch(`{
  "content": *[_type == "siteContent" && page == "Research"]{
    section,
    title,
    description
  }
}`);

const hero = pageData.content.find((s: any) => s.section === "Hero") || {
  title:
    "Pioneering the <span class='text-blue-600'>Next Frontier</span> of Innovation",
  description:
    "Dynage Research is dedicated to solving complex global challenges through rigorous scientific inquiry and advanced technical engineering in AI, Robotics, and IoT.",
};

const mission = pageData.content.find((s: any) => s.section === "Mission") || {
  title: "Advancing Human Potential",
  description:
    "Our dedicated centers for Health, Real Estate, and Finance develop cutting-edge solutions that redefine how we live, work, and interact with the physical and digital world.",
};
---

<Layout title="Research | Dynage Center of Excellence">
  <section
    class="py-20 flex flex-col items-center justify-center text-center my-16"
  >
    <div class="max-w-4xl px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-[1.1]"
        set:html={hero.title}
      />
      <p
        class="text-xl text-gray-600 dark:text-gray-400 mb-10 leading-relaxed max-w-2xl mx-auto"
      >
        {hero.description}
      </p>
      <div class="flex gap-4 justify-center">
        <a
          href="/publications"
          class="px-8 py-3 bg-black dark:bg-white text-white dark:text-black rounded-full font-medium transition-transform hover:scale-105"
        >
          View Publications
        </a>
        <a
          href="/roadmap"
          class="px-8 py-3 border border-black/10 dark:border-white/10 rounded-full font-medium transition-transform hover:scale-105"
        >
          Innovation Roadmap
        </a>
      </div>
    </div>
  </section>

  <main>
    <Section fullWidthBorder>
      <div class="max-w-4xl mx-auto text-center mb-16 px-4">
        <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-6">
          Research <span class="text-blue-600">Domains</span>
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Multi-disciplinary expertise focused on high-impact sectors.
        </p>
      </div>
      <div class="px-4 w-full max-w-7xl mx-auto">
        <IndustryCard />
      </div>
    </Section>

    <SectionSpacer size="md" />

    <Section variant="dark" fullWidthBorder={false}>
      <div class="max-w-5xl mx-auto text-center py-20 px-8">
        <h2
          class="text-3xl md:text-5xl font-bold tracking-tight leading-tight mb-8"
        >
          {mission.title}
        </h2>
        <p class="text-xl text-gray-400 mb-10 max-w-3xl mx-auto">
          {mission.description}
        </p>
        <div class="w-20 h-1 bg-blue-600 mx-auto rounded-full"></div>
      </div>
    </Section>

    <div class="bg-gray-50 dark:bg-black/50 py-12">
      <StatsGrid entryName="research-stats" />
    </div>

    <SectionSpacer size="lg" />
  </main>
</Layout>
