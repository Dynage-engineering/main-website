---
import { type CollectionEntry, getCollection } from "astro:content"
import Layout from "../../layouts/Layout.astro"
import Section from "@dynage/ui/astro/Section.astro"

// Create the static pages for legal docs
export async function getStaticPaths() {
	const docs = await getCollection("legal")
	return docs.map((doc) => ({
		params: { slug: doc.slug },
		props: doc,
	}))
}

// Get the requested legal doc
type Props = CollectionEntry<"legal">;
const doc = Astro.props
const { title, date } = doc.data
const { Content } = await doc.render();

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric"
  });
}
---

<Layout title={title}>
  <section class="pt-32 pb-16 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl md:text-7xl font-black mb-4 tracking-tighter">
        {title}
      </h1>
      <p class="text-gray-500 font-bold uppercase tracking-widest text-sm">
        Last updated: {formatDate(date)}
      </p>
    </div>
  </section>

  <main class="pb-32">
    <Section>
      <div class="max-w-3xl mx-auto px-4 prose prose-lg prose-blue dark:prose-invert">
        <Content/>
      </div>
    </Section>
  </main>
</Layout>