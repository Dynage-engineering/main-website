---
import { client } from "@dynage/contents/client";
import Layout from "../../layouts/Layout.astro";
import Section from "@dynage/ui/astro/Section.astro";
import { PortableText } from "astro-portabletext";

const roadmap =
  await client.fetch(`*[_type == "roadmap"] | order(dateStart desc) {
  projectName,
  niche,
  industry,
  dateStart,
  dateEnd,
  status,
  content
}`);

function formatWorkDate(input: string) {
  if (!input) return "Present";
  const date = new Date(input);
  const month = date.toLocaleDateString("en-US", { month: "short" });
  const year = date.getFullYear();
  return `${month} ${year}`;
}
---

<Layout title="Roadmap | Dynage Research">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-none"
      >
        Innovation <br />
        <span class="text-blue-600">Roadmap</span>
      </h1>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed"
      >
        Tracking our journey through the frontier of AI, Robotics, and IoT
        systems.
      </p>
    </div>
  </section>

  <main class="pb-32">
    <Section>
      <div class="max-w-3xl mx-auto px-4">
        <ul class="space-y-16">
          {
            roadmap.map((entry: any) => (
              <li class="relative pl-8 border-l-2 border-blue-600/20 last:border-none pb-12">
                <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-blue-600" />

                <div class="flex items-center gap-4 mb-4">
                  <div class="text-xs uppercase font-black tracking-widest text-blue-600">
                    {formatWorkDate(entry.dateStart)} -{" "}
                    {formatWorkDate(entry.dateEnd)}
                  </div>
                  {entry.status && (
                    <span class="text-[10px] uppercase font-black px-3 py-1 bg-gray-100 dark:bg-zinc-800 rounded-full text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-zinc-700">
                      {entry.status.replace("-", " ")}
                    </span>
                  )}
                </div>

                <h3 class="text-3xl font-black mb-2 text-black dark:text-white">
                  {entry.projectName}
                </h3>
                <div class="text-sm font-bold uppercase tracking-widest text-gray-400 mb-8">
                  {entry.industry} • {entry.niche}
                </div>
                <article class="prose dark:prose-invert max-w-none text-gray-600 dark:text-gray-400">
                  <PortableText value={entry.content} />
                </article>
              </li>
            ))
          }
        </ul>
      </div>
    </Section>
  </main>
</Layout>
