---
import Section from "@dynage/ui/astro/Section";
import SectionSpacer from "@dynage/ui/astro/SectionSpacer";
import { client, PLACEHOLDER_IMG } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";
import Layout from "@/layouts/Layout.astro";

// Fetch all products from Sanity
const products = await client.fetch(`*[_type == "product"] | order(name asc) {
  name,
  "slug": slug.current,
  category,
  mainImage,
  "excerpt": pt::text(description),
  link
}`);
---

<Layout title="Products | Dynage Technologies">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-none"
      >
        Ready-to-Deploy <br />
        <span class="text-blue-600">Solutions</span>
      </h1>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed pb-10"
      >
        Explore our suite of proprietary products engineered to solve complex
        business challenges across the Dynage ecosystem.
      </p>
    </div>
  </section>

  <main class="pb-32">
    <Section>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 px-4">
        {
          products.map((product: any) => (
            <div class="group flex flex-col bg-gray-50 dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 rounded-[3rem] overflow-hidden transition-all hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-2">
              <div class="aspect-square overflow-hidden bg-gray-200 dark:bg-zinc-800">
                <img
                  src={
                    product.mainImage
                      ? urlFor(product.mainImage).width(600).url()
                      : PLACEHOLDER_IMG
                  }
                  alt={product.name}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              </div>
              <div class="p-10 flex-1 flex flex-col">
                <div class="flex flex-wrap gap-2 mb-4">
                  {product.category?.map((cat: string) => (
                    <span class="text-[10px] uppercase tracking-[0.2em] font-black px-3 py-1 bg-blue-500/10 text-blue-600 rounded-full">
                      {cat}
                    </span>
                  ))}
                </div>
                <h3 class="text-3xl font-black mb-4 group-hover:text-blue-600 transition-colors">
                  {product.name}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-10">
                  {product.excerpt?.length > 100
                    ? product.excerpt.substring(0, 100) + "..."
                    : product.excerpt}
                </p>

                <div class="mt-auto pt-6 border-t border-gray-100 dark:border-zinc-800">
                  {product.link ? (
                    <a
                      href={product.link}
                      target="_blank"
                      class="inline-flex items-center text-blue-600 font-black text-sm group/link"
                    >
                      Launch Product
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4 w-4 ml-2 transition-transform group-hover/link:translate-x-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="3"
                          d="M14 5l7 7m0 0l-7 7m7-7H3"
                        />
                      </svg>
                    </a>
                  ) : (
                    <span class="text-gray-400 font-black text-xs uppercase tracking-widest italic">
                      Internal Deployment
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </Section>

    <SectionSpacer size="lg" />

    <!-- CTA Section -->
    <Section
      variant="dark"
      class="rounded-[4rem] mx-4 mb-32 overflow-hidden relative"
    >
      <div class="absolute inset-0 bg-blue-600 opacity-5 mix-blend-overlay">
      </div>
      <div class="max-w-4xl mx-auto py-24 text-center relative z-10 px-8">
        <h2 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter">
          Looking for a <br />
          <span class="text-blue-500">Custom Built?</span>
        </h2>
        <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
          While our products are ready to use, our Engineering and Studio arms
          specialize in tailored system integration.
        </p>
        <a
          href="https://studio.dynage.technology"
          class="inline-flex px-12 py-5 bg-white text-black rounded-full font-black text-lg transition-transform hover:scale-110"
        >
          Consult with Studio
        </a>
      </div>
    </Section>
  </main>
</Layout>
