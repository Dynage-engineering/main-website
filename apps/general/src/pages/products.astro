---
import Section from "@dynage/ui/astro/Section";
import ProductsGrid from "@dynage/ui/astro/ProductsGrid";
import SectionSpacer from "@dynage/ui/astro/SectionSpacer";
import Layout from "@/layouts/Layout.astro";

---

<Layout title="Products | Dynage Technologies">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-none"
      >
        Ready-to-Deploy <br />
        <span class="text-blue-600">Solutions</span>
      </h1>
      <p
        class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed pb-10"
      >
        Explore our suite of proprietary products engineered to solve complex
        business challenges across the Dynage ecosystem.
      </p>
    </div>
  </section>

  <main class="pb-32">
    <ProductsGrid />

    <SectionSpacer size="lg" />

    <!-- CTA Section -->
    <Section
      variant="dark"
      class="rounded-[4rem] mx-4 mb-32 overflow-hidden relative"
    >
      <div class="absolute inset-0 bg-blue-600 opacity-5 mix-blend-overlay">
      </div>
      <div class="max-w-4xl mx-auto py-24 text-center relative z-10 px-8">
        <h2 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter">
          Looking for a <br />
          <span class="text-blue-500">Custom Built?</span>
        </h2>
        <p class="text-xl text-gray-400 mb-12 max-w-2xl mx-auto">
          While our products are ready to use, our Engineering and Studio arms
          specialize in tailored system integration.
        </p>
        <a
          href="https://studio.dynage.technology"
          class="inline-flex px-12 py-5 bg-white text-black rounded-full font-black text-lg transition-transform hover:scale-110"
        >
          Consult with Studio
        </a>
      </div>
    </Section>
  </main>
</Layout>
