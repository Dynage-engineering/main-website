---
import "@dynage/ui/globals.css";
import { ThemedHeader } from "@dynage/ui/components/themed-header";
import { Footer } from "@dynage/ui/components/footer";
import { SITE, LINKS, LOGO } from "../consts";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description || SITE.DESCRIPTION} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title || SITE.TITLE}</title>
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
    </script>
  </head>
  <body
    class="bg-white dark:bg-black text-black dark:text-white transition-colors duration-300"
  >
    <ThemedHeader
      client:load
      site={SITE}
      links={LINKS}
      logo={LOGO}
      pathname={Astro.url.pathname}
    />
    <main class="pt-16">
      <slot />
    </main>
    <Footer client:load site={SITE} />
  </body>
</html>

<style is:global></style>
