---
import { getCollection } from "astro:content";
import Section from "./Section.astro";
import { client } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";

interface PartnerItem {
    name: string;
    logo?: any;
}

// Fetch from Sanity
const sanityPartners =
    await client.fetch(`*[_type == "partner"] | order(order asc) {
    name,
    logo
}`);

// Local Fallback
const localInvestors = await getCollection("investors");
const localPartners = localInvestors.flatMap((entry) => entry.data as any[]);

const displayPartners =
    sanityPartners?.length > 0 ? sanityPartners : localPartners;
---

<Section as="div" class="py-12" padBlock={false}>
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
            displayPartners.map(({ name, logo }: any) => (
                <li class="group flex flex-col items-center justify-center p-8 rounded-3xl bg-gray-50 dark:bg-black/50 hover:bg-white dark:hover:bg-gray-900 border border-gray-100 dark:border-gray-800 transition-all hover:shadow-xl">
                    {logo?.asset ? (
                        <img
                            src={urlFor(logo).width(200).url()}
                            alt={name}
                            class="w-32 h-32 object-contain grayscale group-hover:grayscale-0 transition-all duration-500"
                        />
                    ) : (
                        <img
                            src={logo}
                            alt={name}
                            class="w-32 h-32 object-contain grayscale group-hover:grayscale-0 transition-all duration-500"
                        />
                    )}
                    <h3 class="mt-4 text-sm font-bold uppercase tracking-widest text-gray-400 group-hover:text-blue-600 transition-colors">
                        {name}
                    </h3>
                </li>
            ))
        }
    </ul>
</Section>
