---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import SectionSpacer from "../../components/SectionSpacer.astro";
import { client } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";
import { PortableText } from "astro-portabletext";

export async function getStaticPaths() {
  const projects = await client.fetch(`*[_type == "project"]{ "slug": slug.current }`);
  return projects.map((p: any) => ({
    params: { slug: p.slug },
  }));
}

const { slug } = Astro.params;

const project = await client.fetch(`*[_type == "project" && slug.current == $slug][0]{
  title,
  description,
  category,
  mainImage,
  technologies,
  projectUrl,
  githubUrl,
  publishedAt,
  body
}`, { slug });

if (!project) return Astro.redirect("/404");
---

<Layout title={`${project.title} | Dynage Engineering`}>
  <article class="pt-32 pb-32">
    <!-- Hero Header -->
    <header class="max-w-5xl mx-auto px-6 mb-16 text-center">
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        {project.category?.map((cat: string) => (
          <span class="text-xs uppercase tracking-widest font-black px-4 py-1.5 bg-blue-600 text-white rounded-full">
            {cat}
          </span>
        ))}
      </div>
      <h1 class="text-5xl md:text-8xl font-black mb-8 tracking-tighter leading-none">
        {project.title}
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
        {project.description}
      </p>
    </header>

    <!-- Main Hero Image -->
    <Section fullWidthBorder={false}>
      <div class="max-w-7xl mx-auto px-4">
        <div class="aspect-[21/9] rounded-[3rem] overflow-hidden shadow-2xl shadow-blue-500/10 border border-gray-100 dark:border-zinc-800">
           {project.mainImage ? (
                <img 
                  src={urlFor(project.mainImage).width(1600).url()} 
                  alt={project.title}
                  class="w-full h-full object-cover"
                />
              ) : (
                <div class="w-full h-full bg-gray-100 dark:bg-zinc-900 flex items-center justify-center">
                   <span class="text-gray-400">Image Coming Soon</span>
                </div>
              )}
        </div>
      </div>
    </Section>

    <SectionSpacer size="md" />

    <!-- Content & Details -->
    <Section>
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-16 lg:gap-32 px-6">
        <!-- Body Content -->
        <div class="prose prose-xl prose-blue dark:prose-invert max-w-none content-wrapper">
          <PortableText value={project.body} />
        </div>

        <!-- Sidebar Details -->
        <aside class="space-y-12">
          {project.technologies && (
            <div>
              <h4 class="text-sm font-black uppercase tracking-widest text-gray-400 mb-6">
                Technologies
              </h4>
              <div class="flex flex-wrap gap-2 text-sm">
                {project.technologies.map((tech: string) => (
                  <span class="px-4 py-2 bg-gray-50 dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 rounded-2xl font-medium">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          )}

          <div class="space-y-6 pt-12 border-t border-gray-100 dark:border-zinc-800">
            {project.projectUrl && (
              <a 
                href={project.projectUrl} 
                target="_blank" 
                class="flex items-center justify-center w-full px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold transition-transform hover:scale-105"
              >
                Launch Live Project
              </a>
            )}
            {project.githubUrl && (
              <a 
                href={project.githubUrl} 
                target="_blank" 
                class="flex items-center justify-center w-full px-8 py-4 border border-blue-600 text-blue-600 rounded-2xl font-bold transition-all hover:bg-blue-50 dark:hover:bg-blue-900/20"
              >
                View Repository
              </a>
            )}
          </div>
        </aside>
      </div>
    </Section>
  </article>

  <!-- CTA Section -->
  <Section variant="dark" class="rounded-[4rem] mx-4 mb-32">
     <div class="max-w-4xl mx-auto py-24 text-center">
        <h2 class="text-4xl md:text-6xl font-black mb-10 tracking-tight">
            Inspired by this <span class="text-blue-500">Project?</span>
        </h2>
        <a href="/solutions" class="inline-flex px-12 py-5 bg-white text-black rounded-full font-black text-lg transition-transform hover:scale-105">
            Discuss Your System
        </a>
     </div>
  </Section>
</Layout>
