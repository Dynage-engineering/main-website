---
import Layout from "../../layouts/Layout.astro";
import ProjectsGrid from "@dynage/ui/astro/ProjectsGrid.astro";
---

<Layout title="Projects | Dynage Engineering">
  <section class="pt-32 pb-20 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h1
        class="text-5xl md:text-8xl font-black mb-6 tracking-tighter leading-none"
      >
        Our <span class="text-blue-600">Innovations</span>
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        A showcase of intelligent systems, automation breakthroughs, and
        engineering excellence across global industries.
      </p>
    </div>
  </section>

  <ProjectsGrid />
</Layout>
