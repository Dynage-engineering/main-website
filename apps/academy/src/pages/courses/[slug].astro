---
import Layout from "../../layouts/Layout.astro";
import type { SanityDocument } from "@sanity/client";
import { client } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";
import { PortableText } from "astro-portabletext";
import { Container } from "@dynage/ui/components/container";
import { Button } from "@dynage/ui/components/button";

import { ChevronLeft } from "lucide-react";

export async function getStaticPaths() {
  const SLUGS_QUERY = `*[_type == "course" && defined(slug.current)]{
    "params": {"slug": slug.current}
  }`;
  return await client.fetch(SLUGS_QUERY);
}

const COURSE_QUERY = `*[_type == "course" && slug.current == $slug][0]`;
const course = await client.fetch<SanityDocument>(COURSE_QUERY, Astro.params);

if (!course) {
  return Astro.redirect("/404");
}

const courseImageUrl = course.mainImage
  ? urlFor(course.mainImage).width(1200).height(675).url()
  : null;
---

<Layout title={`${course.title} | Dynage Academy`}>
  <section class="py-20">
    <Container size="md">
      <a
        href="/courses"
        class="mb-8 inline-flex items-center text-sm font-medium text-gray-500 hover:text-blue-600 transition-colors"
      >
        <ChevronLeft /> Back to all courses
      </a>

      <div class="mt-8 grid grid-cols-1 gap-12 lg:grid-cols-12">
        <div class="lg:col-span-8">
          <h1 class="text-4xl md:text-6xl font-black tracking-tight mb-8">
            {course.title}
          </h1>

          {
            courseImageUrl && (
              <div class="relative aspect-video overflow-hidden rounded-3xl bg-gray-100 shadow-2xl mb-12">
                <img
                  src={courseImageUrl}
                  alt={course.title}
                  class="h-full w-full object-cover"
                />
              </div>
            )
          }

          <div class="prose dark:prose-invert prose-lg max-w-none">
            {
              course.syllabus ? (
                <PortableText value={course.syllabus} />
              ) : (
                <p class="text-gray-500 italic">
                  No syllabus provided for this course yet.
                </p>
              )
            }
          </div>
        </div>

        <aside class="lg:col-span-4 lg:sticky lg:top-24 h-fit">
          <div
            class="rounded-3xl border border-gray-200 dark:border-gray-800 p-8 shadow-sm"
          >
            <h3 class="text-xl font-bold mb-6">Course Information</h3>

            <div class="space-y-6">
              <div>
                <span
                  class="block text-sm text-gray-500 uppercase tracking-wider mb-1"
                  >Expert Instructor</span
                >
                <span class="text-lg font-semibold"
                  >{course.instructor || "Dynage Expert"}</span
                >
              </div>
              <div>
                <span
                  class="block text-sm text-gray-500 uppercase tracking-wider mb-1"
                  >Time Investment</span
                >
                <span class="text-lg font-semibold">{course.duration}</span>
              </div>
              <div>
                <span
                  class="block text-sm text-gray-500 uppercase tracking-wider mb-1"
                  >Challenge Level</span
                >
                <span
                  class="text-lg font-semibold capitalize font-medium px-3 py-1 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-full inline-block"
                >
                  {course.level}
                </span>
              </div>
            </div>
          </div>
          <Button
            className="w-full h-12 text-lg font-bold rounded-xl bg-blue-600  hover:bg-blue-700 text-white transition-all shadow-lg hover:shadow-blue-500/25 mt-4"
          >
            Enroll Now
          </Button>
        </aside>
      </div>
    </Container>
  </section>
</Layout>
