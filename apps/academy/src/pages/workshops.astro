---
import { Container } from "@dynage/ui/components/container";
import WorkshopCard from "../components/WorkshopCard.astro";
import Layout from "../layouts/Layout.astro";
import { client, PLACEHOLDER_IMG } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";

// Fetch workshops from Sanity
const sanityWorkshops = await client.fetch(`*[_type == "workshop"]{
  title,
  "slug": slug.current,
  "image": mainImage,
  date,
  price,
  "description": coalesce(array::join(description[0].children[].text, ""), "No description available")
}`);
---

<Layout title="Workshops | Dynage Academy">
  <section class="py-20 animate">
    <Container size="md">
      <div class="text-center md:text-left py-10">
        <h1 class="text-4xl md:text-6xl font-bold mb-4">Hands-on Workshops</h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mb-10">
          Intensive sessions focused on practical skills and direct application.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 justify-items-center">
        {
          sanityWorkshops?.length > 0 ? (
            sanityWorkshops.map((workshop: any) => (
              <WorkshopCard
                title={workshop.title}
                description={workshop.description}
                image={
                  workshop.image?.asset
                    ? urlFor(workshop.image).width(400).url()
                    : PLACEHOLDER_IMG
                }
                date={
                  workshop.date
                    ? new Date(workshop.date).toLocaleDateString("en-US", {
                        month: "long",
                        day: "numeric",
                        year: "numeric",
                      })
                    : "Date TBD"
                }
                price={workshop.price ? `$${workshop.price}` : "Free"}
                slug={workshop.slug}
              />
            ))
          ) : (
            <p class="text-center text-gray-500">
              No workshops scheduled at the moment. Check back soon!
            </p>
          )
        }
      </div>
    </Container>
  </section>
</Layout>
