{
  "name": "dynage-technology",
  "version": "1.0.0",
  "packageManager": "pnpm@10.4.0",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "dev:web": "nx run-many -t dev --exclude=contents",
    "lint": "nx run-many -t lint",
    "preview": "nx run-many -t preview",
    "deploy": "nx run-many -t deploy",
    "deploy:academy": "pnpm --filter academy run deploy",
    "deploy:engineering": "pnpm --filter engineering run deploy",
    "deploy:finance": "pnpm --filter finance run deploy",
    "deploy:general": "pnpm --filter general run deploy",
    "deploy:research": "pnpm --filter research run deploy",
    "deploy:studio": "pnpm --filter studio run deploy"
  },
  "devDependencies": {
    "nx": "22.6.5",
    "sass-embedded": "^1.83.4",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}