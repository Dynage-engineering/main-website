---
import Section from "./Section.astro";
import { client, PLACEHOLDER_IMG } from "@dynage/contents/client";
import { urlFor } from "@dynage/contents/image";
import { ArrowRight } from "lucide-react";

const products =
    await client.fetch(`*[_type == "product"] | order(publishedAt desc) {
name,
  "slug": slug.current,
  category,
  mainImage,
  "excerpt": pt::text(description),
  link
}`);
---

<main class="pb-32">
    <Section>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-4">
            {
                products.map((product: any) => (
                    <div class="group flex flex-col bg-gray-50 dark:bg-zinc-900 border border-gray-100 dark:border-zinc-800 rounded-[3rem] overflow-hidden transition-all hover:shadow-2xl hover:shadow-blue-500/10 hover:-translate-y-2">
                        <div class="aspect-[16/9] overflow-hidden bg-gray-200 dark:bg-zinc-800">
                            <img
                                src={
                                    product.mainImage
                                        ? urlFor(product.mainImage)
                                              .width(2000)
                                              .url()
                                        : PLACEHOLDER_IMG
                                }
                                alt={product.name}
                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                            />
                        </div>
                        <div class="p-10 flex-1 flex flex-col">
                            <div class="flex flex-wrap gap-2 mb-4">
                                {product.category?.map((cat: string) => (
                                    <span class="text-[10px] uppercase tracking-[0.2em] font-black px-3 py-1 bg-blue-500/10 text-blue-600 rounded-full">
                                        {cat}
                                    </span>
                                ))}
                            </div>
                            <h3 class="text-3xl font-black mb-4 group-hover:text-blue-600 transition-colors">
                                {product.name}
                            </h3>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-10">
                                {product.excerpt?.length > 150
                                    ? product.excerpt.substring(0, 150) + "..."
                                    : product.excerpt}
                            </p>

                            <div class="mt-auto pt-6">
                                {product.link ? (
                                    <a
                                        href={product.link}
                                        target="_blank"
                                        class="inline-flex items-center text-blue-600 font-black text-sm group/link py-3"
                                    >
                                        Launch Product
                                        <ArrowRight className="w-5 h-5 ml-4 transform transition-transform duration-200 group-hover:translate-x-4" />
                                    </a>
                                ) : (
                                    <span class="text-gray-400  font-black text-xs uppercase tracking-widest italic">
                                        Internal Deployment
                                    </span>
                                )}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </Section>
</main>
