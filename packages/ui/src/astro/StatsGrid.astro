---
import { getEntry } from "astro:content";
import Section from "./Section.astro";
import CountUp from "./CountUp.astro";
import { client } from "@dynage/contents/client";

interface StatItem {
  title: string;
  value: number;
  unit: string;
}

// Fetch from Sanity
const sanityStats = await client.fetch(`*[_type == "stat"] | order(order asc) {
  title,
  value,
  unit
}`);

// Local Fallback
const localStatsEntry = await getEntry('stats', Astro.props.entryName);
const localStats = localStatsEntry?.data || [];

const displayStats = sanityStats?.length > 0 ? sanityStats : localStats;
---
<Section class="py-12 bg-gray-50 dark:bg-black/50" padBlock={false}>
    <ul class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 py-12 px-6">
        {displayStats?.map(({ title, value, unit }: StatItem, index: number) => (
            <li 
                class="flex flex-col justify-center text-center animate-fade-in-up opacity-0"
                style={`animation-delay: ${index * 150}ms; animation-fill-mode: forwards;`}
            >
                <div class="mb-2">
                    <CountUp 
                        class="text-6xl md:text-7xl font-black tracking-tighter text-blue-600" 
                        start={0} 
                        end={value} 
                        unit={unit} 
                    />
                </div>
                <p class="text-lg font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                    {title}
                </p>
            </li>
        ))}
    </ul>
</Section>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
</style>