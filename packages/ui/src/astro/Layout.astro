---
import "@dynage/ui/globals.css";
import { ThemedHeader } from "@dynage/ui/components/themed-header";
import { Footer } from "@dynage/ui/components/footer";
import { Container } from "@dynage/ui/components/container";

export interface Props {
  title?: string;
  description?: string;
  site: {
    TITLE: string;
    DESCRIPTION: string;
    URL?: string;
  };
  links: {
    TEXT: string;
    HREF: string;
  }[];
  logo?: {
    DARK?: string;
    LIGHT?: string;
    alt: string;
  };
  text: string;
}

const { title, description, site, links, logo, text } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description || site.DESCRIPTION} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="./favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title ? `${title} | ${site.TITLE}` : site.TITLE}</title>
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }
      window.localStorage.setItem("theme", theme);
    </script>
  </head>
  <body
    class="bg-white dark:bg-black text-black dark:text-white transition-colors duration-300 m-0 scroll-smooth"
  >
    <ThemedHeader
      client:load
      site={site}
      links={links}
      logo={logo}
      text={text}
      pathname={pathname}
    />
    <main class="pt-16 min-h-screen w-full">
      <Container size="lg">
        <slot />
      </Container>
    </main>
    <Footer client:load site={site} />
  </body>
</html>
<style is:global>
  html,
  body {
    margin: 0px;
    scroll-behavior: smooth;
  }
</style>
