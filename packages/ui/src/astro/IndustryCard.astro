---
import { getCollection } from 'astro:content';
import { client } from "@dynage/contents/client";

interface IndustryDiv {
  title: string;
  subtitle: string;
  key_capabilities?: string[];
}

// Fetch from Sanity
const sanityIndustries = await client.fetch(`*[_type == "industry"] | order(order asc) {
  title,
  subtitle,
  key_capabilities
}`);

// Fallback to local
const localIndustriesEntry = await getCollection('industry');
const localIndustries = localIndustriesEntry.flatMap(entry => entry.data as unknown as IndustryDiv[]);

const displayIndustries = sanityIndustries?.length > 0 ? sanityIndustries : localIndustries;



---
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  {
    displayIndustries?.map(
      ({ title, subtitle, key_capabilities }: IndustryDiv, index: number) => (
        <div
          class="group relative overflow-hidden rounded-3xl border border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-900/50 p-8 transition-all hover:bg-white dark:hover:bg-gray-900 hover:shadow-2xl hover:shadow-blue-500/5 hover:-translate-y-1"
        >
          <div class="flex flex-col h-full">
            <h3 class="text-2xl font-bold tracking-tight mb-4 group-hover:text-blue-600 transition-colors">
              {title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed flex-grow">
              {subtitle}
            </p>

            {key_capabilities && (
              <div class="mt-auto">
                <p class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-4">
                  Key Capabilities
                </p>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {key_capabilities.map((item: string) => (
                    <li class="flex items-center text-sm text-gray-500">
                      <span class="mr-2 h-1 w-1 rounded-full bg-blue-600" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      )
    )
  }
</div>
